<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Redirecting...</title>
</head>
<body>
<script>
(function() {
  var nl = (navigator.language || navigator.userLanguage || 'es').toLowerCase();
  var lang = nl.startsWith('ne') ? 'ne' : nl.startsWith('en') ? 'en' : 'es';
  var dest = '/2026-uruguay/' + lang + '/events/';
  // honour legacy ?lang= param if present
  var p = new URLSearchParams(location.search).get('lang');
  if (p === 'en' || p === 'es' || p === 'ne') { lang = p; dest = '/2026-uruguay/' + lang + '/events/'; }
  location.replace(dest);
})();
</script>
<noscript><meta http-equiv="refresh" content="0; url=/2026-uruguay/es/events/"></noscript>
</body>
</html>
